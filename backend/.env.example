PORT=3001
DATABASE_URL=postgres://postgres:postgres@localhost:5432/chatdb
FRONTEND_ORIGINS=https://localhost:5173,http://localhost:5173
SESSION_COOKIE_NAME=chat_session
ZOOKEEPER_HOST=localhost:2181

# TLS do backend. O comando `npm run dev` ja habilita TLS local por padrao.
# Use DEV_TLS_ENABLED=false para desligar no desenvolvimento.
TLS_ENABLED=false
TLS_CERT_PATH=
TLS_KEY_PATH=
COOKIE_SECURE=false

# Para certificados autoassinados em chamadas internas entre backends, use false em desenvolvimento.
INTERNAL_TLS_REJECT_UNAUTHORIZED=true

# ACL do ZooKeeper. O comando `npm run dev` ja habilita ACL local por padrao.
# Use DEV_ZOOKEEPER_ACL_ENABLED=false para desligar no desenvolvimento.
# Exemplo: ZOOKEEPER_AUTH=chat:uma-senha-forte
ZOOKEEPER_AUTH=
ZOOKEEPER_ACL_ENABLED=false
